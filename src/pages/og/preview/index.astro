---
import { getCollection } from 'astro:content';
import { sortItemsByDateDesc } from '../../../utils/data-utils';

const blog = (await getCollection('blog')).sort(sortItemsByDateDesc);
const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>OG card preview</title>
        <meta name="robots" content="noindex" />
        <style>
            body {
                font-family: ui-sans-serif, system-ui, -apple-system, 'Helvetica Neue', Arial, sans-serif;
                background: #0d0c0a;
                color: #f3f1ea;
                margin: 0;
                padding: 32px;
            }
            h1 {
                font-family: 'DM Serif Display', serif;
                font-weight: 400;
                margin: 0 0 8px;
            }
            p {
                color: #8a8576;
                margin: 0 0 24px;
                font-size: 14px;
            }
            h2 {
                font-size: 12px;
                letter-spacing: 0.14em;
                text-transform: uppercase;
                color: #8a8576;
                margin: 24px 0 12px;
                font-weight: 500;
            }
            ul {
                list-style: none;
                padding: 0;
                margin: 0;
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 8px;
            }
            a {
                color: #c9c5b7;
                text-decoration: none;
                font-size: 14px;
                padding: 8px 12px;
                border: 1px solid rgba(243, 241, 234, 0.08);
                border-radius: 4px;
                display: block;
                line-height: 1.3;
            }
            a:hover {
                color: #f3f1ea;
                background: rgba(243, 241, 234, 0.04);
            }
            code {
                font-family: 'JetBrains Mono', monospace;
                font-size: 11px;
                color: #5a5648;
            }
        </style>
    </head>
    <body>
        <h1>OG card preview</h1>
        <p>Live HTML preview of the satori template. Edit <code>src/og/OgCard.tsx</code> and the previews hot-reload. The PNG endpoint uses the same component.</p>

        <h2>Blog</h2>
        <ul>
            {blog.map((post) => <li><a href={`/og/preview/blog/${post.id}/`}>{post.data.title}</a></li>)}
        </ul>

        <h2>Projects</h2>
        <ul>
            {projects.map((project) => <li><a href={`/og/preview/projects/${project.id}/`}>{project.data.title}</a></li>)}
        </ul>
    </body>
</html>
