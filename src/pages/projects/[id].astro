---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import ProjectPreview from '../../components/ProjectPreview.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import { extractHeadingsFromMarkdown } from '../../utils/markdown-utils';

export async function getStaticPaths() {
    const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
    const projectCount = projects.length;
    return projects.map((project, index) => ({
        params: { id: project.id },
        props: {
            project,
            prevProject: index + 1 !== projectCount ? projects[index + 1] : null,
            nextProject: index !== 0 ? projects[index - 1] : null
        }
    }));
}

type Props = {
    project: CollectionEntry<'projects'>;
    prevProject: CollectionEntry<'projects'> | null;
    nextProject: CollectionEntry<'projects'> | null;
};

const { href } = Astro.url;
const { project, prevProject, nextProject } = Astro.props;
const { title, description, publishDate, seo } = project.data;
const { Content } = await render(project);

const headings = extractHeadingsFromMarkdown(project.body || '');

const breadcrumbs = [
    { name: 'Home', url: '/' },
    { name: 'Projects', url: '/projects/' },
    { name: title, url: href }
];
---

<BlogPostLayout
    title={seo?.title ?? title}
    description={seo?.description ?? description}
    image={seo?.image}
    showHeader={false}
    headings={headings}
>
    <Breadcrumbs items={breadcrumbs} class="mb-8" />

    <header class="border-b border-hair pb-8 mb-11">
        <h1 class="font-serif font-normal text-ink text-[clamp(40px,6vw,64px)] leading-none tracking-[-0.025em] m-0 mb-5">
            {title}
        </h1>
        {description && (
            <p class="text-ink-2 text-[17px] leading-relaxed m-0 max-w-[54ch]">{description}</p>
        )}
        {publishDate && (
            <div class="mt-8 flex items-center gap-4 font-mono text-[11.5px] tracking-[0.06em] text-ink-3 uppercase flex-wrap">
                <span>Published <FormattedDate date={publishDate} /></span>
            </div>
        )}
    </header>

    {seo?.image?.src && (
        <figure class="m-0 mb-12 border border-hair-2 overflow-hidden">
            <img src={seo.image.src} alt={seo.image.alt ?? ''} loading="eager" class="block w-full h-auto" />
        </figure>
    )}

    <div class="prose-editorial" id="main-content">
        <Content />
    </div>

    {(prevProject || nextProject) && (
        <section class="mt-20 pt-10 border-t border-hair">
            <h2 class="font-serif font-normal text-[32px] tracking-[-0.015em] m-0 mb-6">View Next</h2>
            <div>
                {nextProject && <ProjectPreview project={nextProject} headingLevel="h3" />}
                {prevProject && <ProjectPreview project={prevProject} headingLevel="h3" />}
            </div>
        </section>
    )}
</BlogPostLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const content = document.getElementById('main-content');
        if (!content) return;
        const headings = content.querySelectorAll('h2, h3, h4, h5, h6');
        headings.forEach((element) => {
            const heading = element as HTMLHeadingElement;
            if (!heading.id) {
                const text = heading.textContent || '';
                heading.id = text
                    .toLowerCase()
                    .replace(/[^\w\s-]/g, '')
                    .replace(/\s+/g, '-')
                    .replace(/^-+|-+$/g, '');
            }
        });
    });
</script>
