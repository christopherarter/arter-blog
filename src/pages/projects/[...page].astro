---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import ProjectPreview from '../../components/ProjectPreview.astro';
import siteConfig from '../../data/site-config';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
    return paginate(projects, { pageSize: siteConfig.projectsPerPage || 8 });
}

type Props = { page: Page<CollectionEntry<'projects'>> };

const { page } = Astro.props;
const portfolio = page.data;
---

<BaseLayout
    title={page.currentPage === 1 ? 'Projects' : `Projects — Page ${page.currentPage} of ${page.lastPage}`}
    description={page.currentPage === 1
        ? "Things I've built, maintained, or contributed to."
        : `Page ${page.currentPage} of projects by Chris Arter — things I've built, maintained, or contributed to.`}
    image={{ src: '/dante-preview.jpg', alt: 'arter.dev projects' }}
    showHeader={false}
>
    <main id="main-content" class="max-w-article mx-auto px-5 pt-12 pb-16 md:px-10 md:pt-16 md:pb-24">
        <header class="border-ink-4 mb-8 border-b pb-10">
            <div class="flex flex-wrap items-baseline justify-between gap-6">
                <h1 class="text-ink m-0 mb-5 font-serif text-[clamp(44px,6vw,72px)] leading-none font-normal tracking-[-0.02em]">Projects</h1>
                <span class="text-ink-3 font-mono text-[11px] tracking-widest uppercase">
                    {page.total} project{page.total === 1 ? '' : 's'}
                </span>
            </div>
            <p class="text-ink-2 m-0 max-w-[54ch] text-[17px] leading-relaxed">Things I've built, maintained, or contributed to.</p>
        </header>
        <div>
            {portfolio.map((project) => <ProjectPreview project={project} />)}
        </div>
        <div class="mt-14">
            <Pagination page={page} />
        </div>
    </main>
</BaseLayout>
