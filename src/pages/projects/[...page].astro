---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import ProjectPreview from '../../components/ProjectPreview.astro';
import siteConfig from '../../data/site-config';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
    return paginate(projects, { pageSize: siteConfig.projectsPerPage || 8 });
}

type Props = { page: Page<CollectionEntry<'projects'>> };

const { page } = Astro.props;
const portfolio = page.data;
---

<BaseLayout
    title="Projects"
    description="Things I've built, maintained, or contributed to."
    image={{ src: '/dante-preview.jpg', alt: 'arter.dev projects' }}
    showHeader={false}
>
    <main class="max-w-article mx-auto px-5 md:px-10 pt-12 md:pt-16 pb-16 md:pb-24">
        <header class="border-b border-ink-4 pb-10 mb-8">
            <div class="flex items-baseline justify-between gap-6 flex-wrap">
                <h1 class="font-serif font-normal text-ink text-[clamp(44px,6vw,72px)] leading-none tracking-[-0.02em] m-0 mb-5">
                    Projects
                </h1>
                <span class="font-mono text-[11px] tracking-widest text-ink-3 uppercase">
                    {page.total} project{page.total === 1 ? '' : 's'}
                </span>
            </div>
            <p class="max-w-[54ch] text-ink-2 text-[17px] leading-relaxed m-0">
                Things I've built, maintained, or contributed to.
            </p>
        </header>
        <div>
            {portfolio.map((project) => <ProjectPreview project={project} />)}
        </div>
        <div class="mt-14">
            <Pagination page={page} />
        </div>
    </main>
</BaseLayout>
