---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostList from '../components/PostList.astro';
import WebsiteSchema from '../components/WebsiteSchema.astro';
import siteConfig from '../data/site-config';
import { sortItemsByDateDesc } from '../utils/data-utils';
import { slugify } from '../utils/common-utils';

type Post = CollectionEntry<'blog'>;

const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);

const LIFE_TAGS = new Set(['Life', 'Career']);
const GARAGE_TAGS = new Set(['Car Stuff', 'Miata', 'NB', 'Cars', 'Garage']);

function hasAny(post: Post, set: Set<string>) {
    return (post.data.tags || []).some((t: string) => set.has(t));
}

const garagePosts = posts.filter((p) => hasAny(p, GARAGE_TAGS));
const lifePosts = posts.filter((p) => !hasAny(p, GARAGE_TAGS) && hasAny(p, LIFE_TAGS));
const techPosts = posts.filter((p) => !hasAny(p, GARAGE_TAGS) && !hasAny(p, LIFE_TAGS));

const numberByPostId = new Map<string, number>();
posts.forEach((post, index) => {
    numberByPostId.set(post.id, posts.length - index);
});

function numbersFor(list: Post[]): number[] {
    return list.map((p) => numberByPostId.get(p.id) ?? 0);
}

const techLatest = techPosts.slice(0, 4);
const lifeLatest = lifePosts.slice(0, 3);
const garageLatest = garagePosts.slice(0, 3);

const tagCounts = new Map<string, number>();
for (const post of posts) {
    for (const tag of post.data.tags || []) {
        tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
    }
}
const topTopics = Array.from(tagCounts.entries())
    .sort((a, b) => b[1] - a[1])
    .slice(0, 8);

type Section = { title: string; posts: Post[]; total: number; href: string };
const sections: Section[] = [];
if (techLatest.length) sections.push({ title: 'Latest in Tech', posts: techLatest, total: techPosts.length, href: '/blog' });
if (lifeLatest.length) sections.push({ title: 'Notes on Living', posts: lifeLatest, total: lifePosts.length, href: '/tags/life' });
if (garageLatest.length) sections.push({ title: 'Cars & Wrenching', posts: garageLatest, total: garagePosts.length, href: '/tags/car-stuff' });
---

<BaseLayout showHeader={false} description={siteConfig.description} image={siteConfig.image}>
    <WebsiteSchema />
    <main>
        <Hero />

        {sections.map(({ title, posts, total, href }) => (
            <section class="max-w-shell mx-auto px-5 md:px-10 pt-14 md:pt-20">
                <header class="grid grid-cols-[1fr_auto] items-baseline gap-6 pb-5 border-b border-ink-4">
                    <h2 class="font-serif font-normal text-[30px] md:text-[40px] leading-none tracking-[-0.02em] m-0 text-ink">
                        {title}
                    </h2>
                    <a
                        href={href}
                        class="font-mono text-[11px] tracking-wider text-ink-3 uppercase hover:text-ink transition-colors"
                    >
                        All {total} posts →
                    </a>
                </header>
                <PostList posts={posts} numbers={numbersFor(posts)} />
            </section>
        ))}

        {topTopics.length > 0 && (
            <section class="max-w-shell mx-auto px-5 md:px-10 pt-14 md:pt-20">
                <header class="grid grid-cols-[1fr_auto] items-baseline gap-6 pb-5 border-b border-ink-4">
                    <h2 class="font-serif font-normal text-[30px] md:text-[40px] leading-none tracking-[-0.02em] m-0 text-ink">
                        Browse by Topic
                    </h2>
                    <a href="/tags" class="font-mono text-[11px] tracking-wider text-ink-3 uppercase hover:text-ink transition-colors">
                        All tags →
                    </a>
                </header>
                <div class="mt-8 border border-hair grid grid-cols-2 md:grid-cols-4 divide-x divide-y divide-hair">
                    {topTopics.map(([tag, count]) => (
                        <a
                            href={`/tags/${slugify(tag)}`}
                            class="py-5 px-6 block text-ink hover:bg-paper-2 transition-colors"
                        >
                            <span class="font-serif text-[22px] tracking-[-0.01em] text-ink mb-1 block">{tag}</span>
                            <span class="font-mono text-[10.5px] tracking-[0.1em] text-ink-3 uppercase">
                                {count} post{count === 1 ? '' : 's'}
                            </span>
                        </a>
                    ))}
                </div>
            </section>
        )}
    </main>
</BaseLayout>
