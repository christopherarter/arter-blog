---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPostLayout from '../layouts/BlogPostLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { extractHeadingsFromMarkdown } from '../utils/markdown-utils';

export async function getStaticPaths() {
    const pages = await getCollection('pages');
    return pages.map((page) => ({
        params: { id: page.id },
        props: { page }
    }));
}

type Props = { page: CollectionEntry<'pages'> };

const { href } = Astro.url;
const { page } = Astro.props;
const { title, description, subtitle, seo } = page.data;
const resolvedDescription = seo?.description ?? description ?? subtitle;
const { Content } = await render(page);

const headings = extractHeadingsFromMarkdown(page.body || '');

const breadcrumbs = [
    { name: 'Home', url: '/' },
    { name: title, url: href }
];
---

<BlogPostLayout title={seo?.title ?? title} description={resolvedDescription} image={seo?.image} showHeader={false} headings={headings}>
    <Breadcrumbs items={breadcrumbs} class="mb-8" />

    <header class="border-hair mb-11 border-b pb-8">
        <h1 class="text-ink m-0 font-serif text-[clamp(40px,6vw,64px)] leading-none font-normal tracking-tight">
            {title}
        </h1>
    </header>
    <div class="prose-editorial">
        <Content />
    </div>
</BlogPostLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const content = document.getElementById('main-content');
        if (!content) return;
        const headings = content.querySelectorAll('h2, h3, h4, h5, h6');
        headings.forEach((element) => {
            const heading = element as HTMLHeadingElement;
            if (!heading.id) {
                const text = heading.textContent || '';
                heading.id = text
                    .toLowerCase()
                    .replace(/[^\w\s-]/g, '')
                    .replace(/\s+/g, '-')
                    .replace(/^-+|-+$/g, '');
            }
        });
    });
</script>
