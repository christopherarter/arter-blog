---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPostLayout from '../layouts/BlogPostLayout.astro';
import { extractHeadingsFromMarkdown } from '../utils/markdown-utils';

export async function getStaticPaths() {
    const pages = await getCollection('pages');
    return pages.map((page) => ({
        params: { id: page.id },
        props: { page }
    }));
}

type Props = { page: CollectionEntry<'pages'> };

const { page } = Astro.props;
const { title, seo } = page.data;
const { Content } = await render(page);

const headings = extractHeadingsFromMarkdown(page.body || '');
---

<BlogPostLayout
    title={seo?.title ?? title}
    description={seo?.description}
    image={seo?.image}
    showHeader={false}
    headings={headings}
>
    <header class="border-b border-hair pb-8 mb-11">
        <h1 class="font-serif font-normal text-ink text-[clamp(40px,6vw,64px)] leading-none tracking-[-0.025em] m-0">
            {title}
        </h1>
    </header>
    <div class="prose-editorial" id="main-content">
        <Content />
    </div>
</BlogPostLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const content = document.getElementById('main-content');
        if (!content) return;
        const headings = content.querySelectorAll('h2, h3, h4, h5, h6');
        headings.forEach((element) => {
            const heading = element as HTMLHeadingElement;
            if (!heading.id) {
                const text = heading.textContent || '';
                heading.id = text
                    .toLowerCase()
                    .replace(/[^\w\s-]/g, '')
                    .replace(/\s+/g, '-')
                    .replace(/^-+|-+$/g, '');
            }
        });
    });
</script>
