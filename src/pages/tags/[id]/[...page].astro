---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
import PostList from '../../../components/PostList.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import siteConfig from '../../../data/site-config';
import { sortItemsByDateDesc, getAllTags, getPostsByTag } from '../../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
    const tags = getAllTags(posts);

    return tags.flatMap((tag) => {
        const filteredPosts = getPostsByTag(posts, tag.id);
        return paginate(filteredPosts, {
            params: { id: tag.id },
            pageSize: siteConfig.postsPerPage || 8
        });
    });
}

type Props = { page: Page<CollectionEntry<'blog'>> };

const { page } = Astro.props;
const blog = page.data;
const params = Astro.params;
const allPosts = await getCollection('blog');
const allTags = getAllTags(allPosts);
const currentTag = allTags.find((tag) => tag.id === params.id);

const startIndex = (page.currentPage - 1) * page.size;
const startNumber = page.total - startIndex;

const breadcrumbs = [
    { name: 'Home', url: '/' },
    { name: 'Tags', url: '/tags/' },
    { name: currentTag?.name ?? '', url: Astro.url.href }
];
---

<BaseLayout
    title={page.currentPage === 1 ? `Posts tagged ${currentTag?.name}` : `Posts tagged ${currentTag?.name} — Page ${page.currentPage} of ${page.lastPage}`}
    description={page.currentPage === 1
        ? `A curated collection of posts under ${currentTag?.name}.`
        : `Page ${page.currentPage} of posts tagged ${currentTag?.name} on arter.dev.`}
    image={{ src: '/dante-preview.jpg', alt: 'arter.dev tag archive' }}
    showHeader={false}
>
    <main id="main-content" class="max-w-article mx-auto px-5 pt-12 pb-16 md:px-10 md:pt-16 md:pb-24">
        <Breadcrumbs items={breadcrumbs} class="mb-8" />
        <header class="border-ink-4 mb-8 flex flex-wrap items-baseline justify-between gap-6 border-b pb-10">
            <h1 class="text-ink m-0 font-serif text-[clamp(44px,6vw,72px)] leading-none font-normal tracking-[-0.02em]">
                {currentTag?.name}
            </h1>
            <span class="text-ink-3 font-mono text-[11px] tracking-widest uppercase">
                {page.total} post{page.total === 1 ? '' : 's'}
            </span>
        </header>
        <PostList posts={blog} startNumber={startNumber} />
        <div class="mt-14">
            <Pagination page={page} />
        </div>
    </main>
</BaseLayout>
