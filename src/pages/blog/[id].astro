---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import { slugify } from '../../utils/common-utils';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import { extractHeadingsFromMarkdown } from '../../utils/markdown-utils';
import ArticleSchema from '../../components/ArticleSchema.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Footnotes from '../../components/Footnotes.astro';

export async function getStaticPaths() {
    const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
    const postCount = posts.length;
    return posts.map((post, index) => ({
        params: { id: post.id },
        props: {
            post,
            prevPost: index + 1 !== postCount ? posts[index + 1] : null,
            nextPost: index !== 0 ? posts[index - 1] : null
        }
    }));
}

type Props = {
    post: CollectionEntry<'blog'>;
    prevPost: CollectionEntry<'blog'> | null;
    nextPost: CollectionEntry<'blog'> | null;
};

const { href } = Astro.url;
const { post, prevPost, nextPost } = Astro.props;
const { title, publishDate, updatedDate, excerpt, tags = [], seo, subtitle } = post.data;
const { Content } = await render(post);

const headings = extractHeadingsFromMarkdown(post.body || '');

const breadcrumbs = [
    { name: 'Home', url: '/' },
    { name: 'Writing', url: '/blog/' },
    { name: title, url: href }
];

function estimateReadTime(body: string | undefined): number {
    if (!body) return 4;
    const words = body.split(/\s+/).filter(Boolean).length;
    return Math.max(3, Math.round(words / 220));
}
const readMinutes = estimateReadTime(post.body);
const coverImage = seo?.image?.src;
const coverAlt = seo?.image?.alt ?? '';
---

<BlogPostLayout
    title={seo?.title ?? title}
    description={seo?.description ?? excerpt}
    image={seo?.image}
    showHeader={false}
    headings={headings}
    publishedTime={publishDate}
    modifiedTime={updatedDate}
    tags={tags}
>
    <ArticleSchema post={post} url={href} />

    <Breadcrumbs items={breadcrumbs} class="mb-6 md:mb-8" hideCurrentOnMobile />

    <header class="border-hair mb-8 border-b pb-6 md:mb-11 md:pb-8">
        <h1 class="blog-post-title text-ink m-0 mb-5 max-w-[18ch] font-serif text-[clamp(40px,6vw,72px)] leading-none font-normal tracking-[-0.028em]">
            {title}
        </h1>
        {subtitle && <p class="text-ink-2 m-0 mb-6 max-w-[42ch] font-serif text-[22px] leading-[1.32] font-normal italic md:mb-8 md:text-[24px]">{subtitle}</p>}
        <div
            class="text-ink-3 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[11px] tracking-[0.12em] uppercase md:gap-x-4 md:text-[11.5px] md:tracking-[0.06em]"
        >
            <span class="text-ink font-medium">Chris Arter</span>
            {
                publishDate && (
                    <>
                        <span class="text-ink-4" aria-hidden="true">
                            ·
                        </span>
                        <span>
                            <>
                                <span class="sr-only md:not-sr-only md:mr-1">Published</span>
                                <FormattedDate date={publishDate} format="responsive" />
                            </>
                        </span>
                    </>
                )
            }
            <span class="text-ink-4" aria-hidden="true">·</span>
            <span>{readMinutes} min<span class="hidden md:inline"> read</span></span>
            {
                updatedDate && (
                    <>
                        <span class="text-ink-4 hidden md:inline" aria-hidden="true">
                            ·
                        </span>
                        <span class="hidden md:inline">
                            Updated <FormattedDate date={updatedDate} />
                        </span>
                    </>
                )
            }
        </div>
    </header>

    {
        coverImage && (
            <figure class="border-hair-2 m-0 mb-[52px] aspect-video overflow-hidden border">
                <img src={coverImage} alt={coverAlt} loading="eager" decoding="async" class="block h-full w-full object-cover" />
            </figure>
        )
    }

    <div class="prose-editorial">
        <Content />
        <Footnotes />
    </div>

    {
        tags.length > 0 && (
            <div class="border-hair tracking-mono mt-12 flex flex-wrap gap-4 border-t pt-5 font-mono text-xs uppercase">
                {tags.map((tag) => (
                    <a href={`/tags/${slugify(tag)}`} class="text-ink-3 hover:text-ink hover:decoration-ink-4 hover:underline hover:underline-offset-[3px]">
                        #{tag}
                    </a>
                ))}
            </div>
        )
    }

    {
        (prevPost || nextPost) && (
            <nav class="border-hair mt-16 grid grid-cols-1 gap-6 border-t pt-10 md:grid-cols-2 md:gap-10" aria-label="Post navigation">
                {prevPost ? (
                    <a href={`/blog/${prevPost.id}/`} class="group text-ink block no-underline">
                        <div class="text-ink-3 mb-2 font-mono text-[10.5px] tracking-[0.18em] uppercase">← Previous</div>
                        <div class="text-ink group-hover:decoration-ink-4 font-serif text-[22px] leading-tight tracking-[-0.01em] group-hover:underline group-hover:underline-offset-[3px]">
                            {prevPost.data.title}
                        </div>
                    </a>
                ) : (
                    <span />
                )}
                {nextPost ? (
                    <a href={`/blog/${nextPost.id}/`} class="group text-ink block no-underline md:text-right">
                        <div class="text-ink-3 mb-2 font-mono text-[10.5px] tracking-[0.18em] uppercase">Next →</div>
                        <div class="text-ink group-hover:decoration-ink-4 font-serif text-[22px] leading-tight tracking-[-0.01em] group-hover:underline group-hover:underline-offset-[3px]">
                            {nextPost.data.title}
                        </div>
                    </a>
                ) : (
                    <span />
                )}
            </nav>
        )
    }

    <div class="mt-[72px]">
        <div class="giscus"></div>
        <script
            src="https://giscus.app/client.js"
            data-repo="christopherarter/arter-blog"
            data-repo-id="R_kgDONtMC0Q"
            data-category="General"
            data-category-id="DIC_kwDONtMC0c4Cmpzl"
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="bottom"
            data-theme="dark"
            data-lang="en"
            crossorigin="anonymous"
            async></script>
    </div>
</BlogPostLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const content = document.getElementById('main-content');
        if (content) {
            const headings = content.querySelectorAll('h2, h3, h4, h5, h6');
            headings.forEach((element) => {
                const heading = element as HTMLHeadingElement;
                if (!heading.id) {
                    const text = heading.textContent || '';
                    heading.id = text
                        .toLowerCase()
                        .replace(/[^\w\s-]/g, '')
                        .replace(/\s+/g, '-')
                        .replace(/^-+|-+$/g, '');
                }
            });
        }

        const citations = document.querySelectorAll('.source-citation');
        const footnotesList = document.querySelector('.footnotes-list');
        const footnotesContainer = document.getElementById('footnotes');
        if (citations.length > 0 && footnotesList && footnotesContainer) {
            const sources: Array<{ num: number; url: string; title: string }> = [];
            citations.forEach((cite, index) => {
                const url = cite.getAttribute('data-source-url') || '';
                const title = cite.getAttribute('data-source-title') || url;
                const num = index + 1;
                cite.textContent = `[${num}]`;
                cite.setAttribute('href', `#footnote-${num}`);
                cite.id = `citation-${num}`;
                sources.push({ num, url, title });
            });
            sources.forEach(({ num, url, title }) => {
                const li = document.createElement('li');
                li.id = `footnote-${num}`;
                li.innerHTML = `<a href="${url}" target="_blank" rel="noopener" class="text-ink hover:underline">${title}</a> <a href="#citation-${num}" class="text-ink/60 hover:text-ink ml-1">↩</a>`;
                footnotesList.appendChild(li);
            });
            footnotesContainer.classList.remove('hidden');
        }
    });
</script>
