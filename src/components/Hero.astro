---
const portraitSrc = '/images/chris-arter-pen.png';
---

<section class="border-hair-2 overflow-hidden border-b py-14 md:py-20">
    <div class="max-w-shell mx-auto grid items-center gap-10 px-5 md:grid-cols-[220px_1fr] md:gap-14 md:px-10">
        <div class="max-w-[260px]">
            <div class="aspect-square w-full">
                <img src={portraitSrc} alt="Portrait of Chris Arter" class="block h-full w-full object-contain" />
            </div>
        </div>
        <div>
            <h1 class="text-ink mb-7 font-serif text-[clamp(52px,7vw,88px)] leading-[0.95] font-normal tracking-[-0.03em]">
                Artisan, <br />
                Tinkerer, <br />
                <em class="text-ink-2 italic">Builder</em>.
            </h1>
            <p class="text-ink-2 m-0 max-w-[54ch] text-[17px] leading-relaxed text-pretty">
                Hey there, I'm <strong>Chris Arter</strong>, a software engineer in Raleigh, North Carolina. I write about software, life, and the best sports
                car ever made: the Mazda Miata.
            </p>
            <dl class="border-hair mt-8 grid grid-cols-2 gap-6 border-t pt-5 font-mono md:grid-cols-4">
                <div>
                    <dt class="text-ink-3 mb-1.5 text-[10px] tracking-widest uppercase">Based</dt>
                    <dd class="text-ink m-0 text-[12.5px] tracking-wide">Raleigh, NC</dd>
                </div>
                <div>
                    <dt class="text-ink-3 mb-1.5 text-[10px] tracking-widest uppercase">Writing since</dt>
                    <dd class="text-ink m-0 text-[12.5px] tracking-wide">2014</dd>
                </div>
                <div>
                    <dt class="text-ink-3 mb-1.5 text-[10px] tracking-widest uppercase">Stack</dt>
                    <dd class="text-ink m-0 text-[12.5px] tracking-wide">Laravel · Typescript · Docker</dd>
                </div>
                <div>
                    <dt class="text-ink-3 mb-1.5 text-[10px] tracking-widest uppercase">Status</dt>
                    <dd class="text-ink m-0 text-[12.5px] tracking-wide">Open to say hello</dd>
                </div>
            </dl>
        </div>
    </div>
</section>
