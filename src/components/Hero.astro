---
const portraitSrc = '/images/chris-arter-pen.png';
---

<section class="py-14 md:py-20 border-b border-hair-2 overflow-hidden">
    <div class="grid items-center gap-10 md:grid-cols-[220px_1fr] md:gap-14 max-w-shell mx-auto px-5 md:px-10">
        <div class="max-w-[260px]">
            <div class="aspect-square w-full">
                <img src={portraitSrc} alt="Portrait of Chris Arter" class="w-full h-full object-contain block" />
            </div>
        </div>
        <div>
            <h1 class="font-serif font-normal text-ink text-[clamp(52px,7vw,88px)] leading-[0.95] tracking-[-0.03em] mb-7">
                Artisan, <br />
                Tinkerer, <br />
                <em class="italic text-ink-2">Builder</em>.
            </h1>
            <p class="text-[17px] leading-relaxed text-ink-2 max-w-[54ch] m-0 [text-wrap:pretty]">
                Hey there, I'm <strong>Chris Arter</strong>, a software engineer in Raleigh, North Carolina. I write about software, life, and the best sports
                car ever made: the Mazda Miata.
            </p>
            <dl class="mt-8 pt-5 border-t border-hair grid grid-cols-2 md:grid-cols-4 gap-6 font-mono">
                <div>
                    <dt class="text-ink-4 mb-1.5 text-[10px] tracking-widest uppercase">Based</dt>
                    <dd class="m-0 text-ink text-[12.5px] tracking-wide">Raleigh, NC</dd>
                </div>
                <div>
                    <dt class="text-ink-4 mb-1.5 text-[10px] tracking-widest uppercase">Writing since</dt>
                    <dd class="m-0 text-ink text-[12.5px] tracking-wide">2014</dd>
                </div>
                <div>
                    <dt class="text-ink-4 mb-1.5 text-[10px] tracking-widest uppercase">Stack</dt>
                    <dd class="m-0 text-ink text-[12.5px] tracking-wide">Laravel · Typescript · Docker</dd>
                </div>
                <div>
                    <dt class="text-ink-4 mb-1.5 text-[10px] tracking-widest uppercase">Status</dt>
                    <dd class="m-0 text-ink text-[12.5px] tracking-wide">Open to say hello</dd>
                </div>
            </dl>
        </div>
    </div>
</section>
