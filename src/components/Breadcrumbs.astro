---
import BreadcrumbSchema from './BreadcrumbSchema.astro';

interface BreadcrumbItem {
    name: string;
    url: string;
}

interface Props {
    items: BreadcrumbItem[];
    class?: string;
    hideCurrentOnMobile?: boolean;
}

const { items, class: className, hideCurrentOnMobile = false } = Astro.props;

const origin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const absoluteItems = items.map((item) => ({
    name: item.name,
    url: item.url.startsWith('http') ? item.url : `${origin}${item.url}`
}));

const lastIndex = items.length - 1;
---

<BreadcrumbSchema items={absoluteItems} />

<nav aria-label="Breadcrumb" class:list={['not-prose', className]}>
    <ol class="m-0 flex list-none flex-wrap items-center gap-x-2 gap-y-1 p-0 font-mono text-[11px] tracking-widest uppercase">
        {
            items.map((item, i) => {
                const isLast = i === lastIndex;
                const hideOnMobile = isLast && hideCurrentOnMobile && items.length > 1;
                return (
                    <li class:list={['min-w-0 items-center gap-2', hideOnMobile ? 'hidden md:flex' : 'flex']}>
                        {i > 0 && (
                            <span aria-hidden="true" class="text-ink-4 select-none">
                                /
                            </span>
                        )}
                        {isLast ? (
                            <span aria-current="page" class="text-ink inline-flex max-w-[36ch] items-baseline gap-1.5 truncate">
                                <span aria-hidden="true" class="text-ink-4 font-normal">
                                    [
                                </span>
                                <span class="truncate">{item.name}</span>
                                <span aria-hidden="true" class="text-ink-4 font-normal">
                                    ]
                                </span>
                            </span>
                        ) : (
                            <a
                                href={item.url}
                                class="text-ink-3 hover:text-ink focus-visible:text-ink no-underline transition-colors focus-visible:outline-none"
                            >
                                {item.name}
                            </a>
                        )}
                    </li>
                );
            })
        }
    </ol>
</nav>
