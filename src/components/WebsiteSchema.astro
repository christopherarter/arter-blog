---
import siteConfig from '../data/site-config';

const websiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": siteConfig.title,
    "description": siteConfig.description,
    "url": "https://arter.dev",
    "author": {
        "@type": "Person",
        "name": "Chris Arter",
        "url": "https://arter.dev"
    },
    "publisher": {
        "@type": "Person",
        "name": "Chris Arter",
        "url": "https://arter.dev",
        "image": {
            "@type": "ImageObject",
            "url": "https://arter.dev/images/chris-arter.jpg"
        }
    }
};
---

<script type="application/ld+json" set:html={JSON.stringify(websiteSchema, null, 2)} />