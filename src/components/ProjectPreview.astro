---
import { type CollectionEntry } from 'astro:content';

type Props = { project: CollectionEntry<'projects'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, description } = project.data;
const TitleTag = headingLevel;
---

<a
    href={`/projects/${project.id}/`}
    class:list={[
        'group grid grid-cols-[1fr_auto] gap-8 py-7 border-b border-hair text-ink no-underline transition-[padding] duration-200 ease-out hover:pl-3',
        className
    ]}
>
    <div>
        <TitleTag class="font-serif font-normal text-[28px] leading-tight tracking-[-0.015em] m-0 mb-2.5 group-hover:underline group-hover:decoration-ink-4 group-hover:underline-offset-4">
            {title}
        </TitleTag>
        {description && <p class="text-ink-2 text-[15px] leading-[1.55] m-0">{description}</p>}
    </div>
    <span class="self-center text-ink-3 font-mono text-base opacity-0 transition-opacity group-hover:opacity-100">→</span>
</a>
