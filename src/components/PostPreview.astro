---
import { type CollectionEntry } from 'astro:content';

type Props = {
    post: CollectionEntry<'blog'>;
    number: number;
    class?: string;
};

const { post, number, class: className } = Astro.props;
const { title, publishDate, excerpt, tags = [] } = post.data;

function formatDate(date: Date) {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}.${m}.${d}`;
}

function estimateReadTime(body: string | undefined): number {
    if (!body) return 4;
    const words = body.split(/\s+/).filter(Boolean).length;
    return Math.max(3, Math.round(words / 220));
}

const paddedNumber = String(number).padStart(3, '0');
const formattedDate = formatDate(new Date(publishDate));
const readMinutes = estimateReadTime(post.body);
const topTags = tags.slice(0, 3);
---

<li class:list={['list-none border-b border-hair group', className]}>
    <a
        href={`/blog/${post.id}/`}
        class="grid grid-cols-1 sm:grid-cols-[200px_1fr_auto] gap-2 sm:gap-8 items-start py-6 sm:py-7 text-ink transition-[padding] duration-200 ease-out hover:pl-3"
    >
        <div class="hidden sm:flex font-mono text-[11px] tracking-wider text-ink-3 flex-col gap-1.5">
            <span class="font-serif text-[48px] leading-[0.9] text-ink font-normal tracking-[-0.02em]">
                {paddedNumber}
            </span>
            <span class="text-ink-3 tabular-nums">{formattedDate}</span>
        </div>

        <div class="max-w-[60ch]">
            <div class="sm:hidden font-mono text-[11px] tracking-wider text-ink-3 tabular-nums mb-2.5">
                {formattedDate}
            </div>
            <h3 class="font-serif font-normal text-[24px] sm:text-[32px] leading-tight tracking-[-0.015em] m-0 mb-2.5 text-ink group-hover:underline group-hover:decoration-ink-4 group-hover:underline-offset-4">
                {title}
            </h3>
            {excerpt && (
                <p class="text-ink-2 text-[15px] leading-[1.55] m-0 text-pretty">{excerpt}</p>
            )}
            {topTags.length > 0 && (
                <div class="flex gap-2 mt-3 font-mono text-[10px] tracking-[0.1em] text-ink-3 uppercase flex-wrap">
                    {topTags.map((tag, i) => (
                        <span>
                            {i > 0 && <span class="mr-2 text-ink-4">·</span>}
                            {tag}
                        </span>
                    ))}
                </div>
            )}
        </div>

        <div class="font-mono text-[11px] tracking-mono text-ink-3 uppercase text-left sm:text-right sm:min-w-[100px] mt-2 sm:mt-0">
            {readMinutes} min
            <span class="ml-1.5 text-ink opacity-0 transition-opacity group-hover:opacity-100">→</span>
        </div>
    </a>
</li>
