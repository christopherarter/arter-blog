---
import { type CollectionEntry } from 'astro:content';

type Props = {
    post: CollectionEntry<'blog'>;
    number: number;
    class?: string;
};

const { post, number, class: className } = Astro.props;
const { title, publishDate, excerpt, tags = [] } = post.data;

function formatDate(date: Date) {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}.${m}.${d}`;
}

function estimateReadTime(body: string | undefined): number {
    if (!body) return 4;
    const words = body.split(/\s+/).filter(Boolean).length;
    return Math.max(3, Math.round(words / 220));
}

const paddedNumber = String(number).padStart(3, '0');
const formattedDate = formatDate(new Date(publishDate));
const readMinutes = estimateReadTime(post.body);
const topTags = tags.slice(0, 3);
---

<li class:list={['border-hair group list-none border-b', className]}>
    <a
        href={`/blog/${post.id}/`}
        class="text-ink grid grid-cols-1 items-start gap-2 py-6 transition-[padding] duration-200 ease-out hover:pl-3 sm:grid-cols-[200px_1fr_auto] sm:gap-8 sm:py-7"
    >
        <div class="text-ink-3 hidden flex-col gap-1.5 font-mono text-[11px] tracking-wider sm:flex">
            <span class="text-ink font-serif text-[48px] leading-[0.9] font-normal tracking-[-0.02em]">
                {paddedNumber}
            </span>
            <span class="text-ink-3 tabular-nums">{formattedDate}</span>
        </div>

        <div class="max-w-[60ch]">
            <div class="text-ink-3 mb-2.5 font-mono text-[11px] tracking-wider tabular-nums sm:hidden">
                {formattedDate}
            </div>
            <h2
                class="text-ink group-hover:decoration-ink-4 m-0 mb-2.5 font-serif text-[24px] leading-tight font-normal tracking-[-0.015em] group-hover:underline group-hover:underline-offset-4 sm:text-[32px]"
            >
                {title}
            </h2>
            {excerpt && <p class="text-ink-2 m-0 text-[15px] leading-[1.55] text-pretty">{excerpt}</p>}
            {
                topTags.length > 0 && (
                    <div class="text-ink-3 mt-3 flex flex-wrap gap-2 font-mono text-[10px] tracking-[0.1em] uppercase">
                        {topTags.map((tag, i) => (
                            <span>
                                {i > 0 && <span class="text-ink-4 mr-2">·</span>}
                                {tag}
                            </span>
                        ))}
                    </div>
                )
            }
        </div>

        <div class="tracking-mono text-ink-3 mt-2 text-left font-mono text-[11px] uppercase sm:mt-0 sm:min-w-[100px] sm:text-right">
            {readMinutes} min
            <span class="text-ink ml-1.5 opacity-0 transition-opacity group-hover:opacity-100">→</span>
        </div>
    </a>
</li>
