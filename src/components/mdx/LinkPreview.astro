---
import { fetchOpenGraph } from '../../utils/og';

interface Props {
    url: string;
    title?: string;
    description?: string;
    image?: string;
    siteName?: string;
}

const { url, title: titleProp, description: descriptionProp, image: imageProp, siteName: siteNameProp } = Astro.props;

const og = titleProp && imageProp && descriptionProp ? null : await fetchOpenGraph(url);

let hostname = url;
try {
    hostname = new URL(url).hostname.replace(/^www\./, '');
} catch {
    /* keep raw url */
}

const title = titleProp ?? og?.title ?? hostname;
const description = descriptionProp ?? og?.description;
const image = imageProp ?? og?.image;
const siteName = siteNameProp ?? og?.siteName ?? hostname;
const isExternal = /^https?:\/\//i.test(url);
---

<a
    class:list={['link-preview', { 'link-preview--no-media': !image }]}
    href={url}
    target={isExternal ? '_blank' : undefined}
    rel={isExternal ? 'external noopener noreferrer' : undefined}
>
    {
        image && (
            <div class="link-preview__media">
                <img
                    src={image}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                    onerror="this.closest('.link-preview__media')?.remove()"
                />
            </div>
        )
    }
    <div class="link-preview__body">
        <div class="link-preview__meta">
            <span class="link-preview__site">{siteName}</span>
            <span class="link-preview__arrow" aria-hidden="true">↗</span>
        </div>
        <div class="link-preview__title">{title}</div>
        {description && <p class="link-preview__desc">{description}</p>}
        {isExternal && <span class="sr-only">(opens in a new tab)</span>}
    </div>
</a>

<style>
    .link-preview {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        position: relative;
        margin-block: 1.75em;
        text-decoration: none;
        color: inherit;
        background: rgb(var(--paper-2));
        border: 1px solid rgba(243, 241, 234, 0.1);
        border-radius: 4px;
        overflow: hidden;
        isolation: isolate;
        transition:
            border-color 240ms ease,
            background-color 240ms ease,
            transform 240ms ease;
    }

    .link-preview::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2px;
        background: rgb(var(--ink-4));
        transform: scaleY(0);
        transform-origin: top center;
        transition: transform 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
        z-index: 1;
    }

    .link-preview:hover {
        border-color: rgba(243, 241, 234, 0.22);
        background: rgb(var(--paper-3));
    }

    .link-preview:hover::before,
    .link-preview:focus-visible::before {
        transform: scaleY(1);
    }

    @media (min-width: 640px) {
        .link-preview:not(.link-preview--no-media) {
            grid-template-columns: minmax(180px, 38%) minmax(0, 1fr);
        }
    }

    .link-preview__media {
        position: relative;
        overflow: hidden;
        background: rgb(var(--paper-3));
        aspect-ratio: 1.91 / 1;
    }

    @media (min-width: 640px) {
        .link-preview__media {
            aspect-ratio: auto;
            min-height: 100%;
            border-right: 1px solid rgba(243, 241, 234, 0.08);
        }
    }

    .link-preview__media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 520ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .link-preview:hover .link-preview__media img {
        transform: scale(1.025);
    }

    .link-preview__body {
        padding: 1.1rem 1.35rem 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        min-width: 0;
    }

    .link-preview__meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        line-height: 1.3;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-weight: 500;
        color: rgb(var(--ink-3));
    }

    .link-preview__site {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
    }

    .link-preview__arrow {
        flex-shrink: 0;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 13px;
        letter-spacing: 0;
        color: rgb(var(--ink-4));
        transform: translate(0, 0);
        transition:
            transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1),
            color 240ms ease;
    }

    .link-preview:hover .link-preview__arrow,
    .link-preview:focus-visible .link-preview__arrow {
        transform: translate(2px, -2px);
        color: rgb(var(--ink));
    }

    .link-preview__title {
        font-family: 'DM Serif Display', 'DM Serif Text', serif;
        font-size: 22px;
        line-height: 1.22;
        font-weight: 400;
        letter-spacing: -0.01em;
        color: rgb(var(--ink));
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin: 0.1rem 0 0;
    }

    .link-preview__desc {
        margin: 0.15rem 0 0;
        font-family: 'Inter Variable', ui-sans-serif, system-ui, sans-serif;
        font-size: 14.5px;
        line-height: 1.55;
        color: rgb(var(--ink-2));
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
