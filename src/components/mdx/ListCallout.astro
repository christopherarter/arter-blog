---
interface Props {
    title: string;
    description?: string;
    class?: string;
}

const { title, description, class: className = '' } = Astro.props;
---

<aside class:list={['list-callout', className]}>
    <header class="list-callout__header">
        <span class="list-callout__title">{title}</span>
        {description && <span class="list-callout__desc">{description}</span>}
    </header>
    <div class="list-callout__body">
        <slot />
    </div>
</aside>

<style>
    .list-callout {
        border: 1px solid rgba(243, 241, 234, 0.1);
        background: rgb(var(--paper-2));
        border-radius: 4px;
        padding: 1.25rem 1.5rem 1.35rem;
        position: relative;
    }

    .list-callout::before {
        content: '';
        position: absolute;
        inset: 0 auto 0 0;
        width: 2px;
        background: rgb(var(--ink-4));
        border-radius: 4px 0 0 4px;
    }

    .list-callout__header {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding-bottom: 0.75rem;
        margin-bottom: 0.9rem;
        border-bottom: 1px solid rgba(243, 241, 234, 0.08);
    }

    .list-callout__title {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        line-height: 1.3;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-weight: 500;
        color: rgb(var(--ink-3));
    }

    .list-callout__desc {
        font-size: 14px;
        line-height: 1.5;
        color: rgb(var(--ink-3));
    }

    .list-callout__body :global(ul),
    .list-callout__body :global(ol) {
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .list-callout__body :global(li) {
        position: relative;
        padding: 0.3rem 0 0.3rem 1.1rem;
        font-size: 16px;
        line-height: 1.5;
        color: rgb(var(--ink-2));
    }

    .list-callout__body :global(li) + :global(li) {
        border-top: 1px solid rgba(243, 241, 234, 0.05);
    }

    .list-callout__body :global(ul) :global(li)::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.95rem;
        width: 4px;
        height: 4px;
        background: rgb(var(--ink-4));
        border-radius: 1px;
    }

    .list-callout__body :global(ol) {
        counter-reset: list-callout;
    }

    .list-callout__body :global(ol) :global(li) {
        counter-increment: list-callout;
        padding-left: 1.75rem;
    }

    .list-callout__body :global(ol) :global(li)::before {
        content: counter(list-callout, decimal-leading-zero);
        position: absolute;
        left: 0;
        top: 0.35rem;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        letter-spacing: 0.1em;
        color: rgb(var(--ink-4));
    }

    .list-callout__body :global(strong) {
        color: rgb(var(--ink));
        font-weight: 550;
    }

    .list-callout__body :global(a) {
        color: rgb(var(--ink));
        text-decoration: underline;
        text-decoration-color: rgb(var(--ink-4));
        text-underline-offset: 3px;
    }

    .list-callout__body :global(a:hover) {
        text-decoration-color: rgb(var(--ink));
    }
</style>
