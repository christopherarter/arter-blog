---
import PostPreview from './PostPreview.astro';
import { type CollectionEntry } from 'astro:content';

type Props = {
    posts: CollectionEntry<'blog'>[];
    numbers?: number[];
    startNumber?: number;
};

const { posts, numbers, startNumber } = Astro.props;

function numberFor(index: number, post: CollectionEntry<'blog'>): number {
    if (numbers && numbers[index] !== undefined) return numbers[index];
    if (startNumber !== undefined) return startNumber - index;
    return posts.length - index;
}
---

<ul class="m-0 list-none p-0">
    {posts.map((post, i) => <PostPreview post={post} number={numberFor(i, post)} />)}
</ul>
