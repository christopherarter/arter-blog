---
import type { Heading } from '../utils/markdown-utils';

type Props = {
    headings: Heading[];
    title?: string;
    showTitle?: boolean;
};

const { headings, title = 'Contents', showTitle = true } = Astro.props;

function flatten(list: Heading[], depth = 0, acc: Array<Heading & { depth: number }> = []) {
    for (const h of list) {
        acc.push({ ...h, depth });
        if (h.children?.length) flatten(h.children, depth + 1, acc);
    }
    return acc;
}

const flat = flatten(headings);
---

{
    flat.length > 0 && (
        <nav class="toc-nav" aria-label="Article sections navigation">
            {showTitle && (
                <p class="text-ink-3 border-hair m-0 mb-4 flex justify-between border-b pb-3 font-mono text-[11px] tracking-[0.18em] uppercase">
                    <span>{title}</span>
                    <span class="text-ink-4">{flat.length}</span>
                </p>
            )}
            <ul class="m-0 list-none p-0">
                {flat.map((h) => (
                    <li class:list={['py-[5px]', { 'pl-3.5': h.depth > 0 }]}>
                        <a
                            href={`#${h.id}`}
                            data-heading-id={h.id}
                            class:list={[
                                'toc-link text-ink-3 hover:text-ink relative flex items-start gap-2.5 pl-3.5 leading-snug no-underline transition-colors',
                                h.depth > 0 ? 'text-[12.5px]' : 'text-[13px]'
                            ]}
                        >
                            {h.text}
                        </a>
                    </li>
                ))}
            </ul>
        </nav>
    )
}

<style>
    .toc-link::before {
        content: '';
        position: absolute;
        left: 0;
        top: 9px;
        width: 6px;
        height: 1px;
        background: rgb(var(--ink-4));
    }
    .toc-link.active {
        color: rgb(var(--ink));
    }
    .toc-link.active::before {
        background: rgb(var(--ink));
        width: 8px;
    }
</style>

<script>
    function initTocScrollSpy() {
        const navs = Array.from(document.querySelectorAll('.toc-nav'));
        if (navs.length === 0) return;

        const allLinks = navs.flatMap((nav) => Array.from(nav.querySelectorAll<HTMLAnchorElement>('a[data-heading-id]')));
        const idSet = new Set(allLinks.map((a) => a.dataset.headingId).filter(Boolean) as string[]);
        const headings = Array.from(idSet)
            .map((id) => document.getElementById(id))
            .filter((el): el is HTMLElement => !!el);

        function onScroll() {
            const y = window.scrollY + 140;
            let currentId = headings[0]?.id;
            for (const h of headings) {
                if (h.offsetTop <= y) currentId = h.id;
            }
            allLinks.forEach((a) => a.classList.toggle('active', a.dataset.headingId === currentId));
        }

        let ticking = false;
        window.addEventListener('scroll', () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => {
                onScroll();
                ticking = false;
            });
        });

        allLinks.forEach((a) => {
            a.addEventListener('click', (e) => {
                const id = a.dataset.headingId;
                if (!id) return;
                const target = document.getElementById(id);
                if (!target) return;
                e.preventDefault();
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                history.pushState(null, '', `#${id}`);
            });
        });

        onScroll();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTocScrollSpy);
    } else {
        initTocScrollSpy();
    }
    document.addEventListener('astro:page-load', initTocScrollSpy);
</script>
