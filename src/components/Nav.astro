---
import siteConfig from '../data/site-config';

const navLinks = siteConfig.headerNavLinks || [];
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
    if (href === '/') return currentPath === '/';
    return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="sticky top-0 z-50 bg-paper border-b border-hair">
    <div class="grid grid-cols-[auto_1fr_auto] items-center gap-4 md:gap-8 h-[72px] max-w-shell mx-auto px-5 md:px-10">
        <a href="/" class="flex items-center gap-3.5 text-ink">
            <span class="font-mono text-[20px] font-medium leading-none tracking-[-0.01em] text-ink inline-flex items-baseline">
                <span class="text-ink-4 font-normal">[</span>arter.dev<span class="text-ink-4 font-normal">]</span>
            </span>
            <span class="hidden md:inline font-mono text-[10.5px] tracking-wider uppercase text-ink-3">
                A Log of Tech &amp; Cars
            </span>
        </a>

        <ul class="hidden md:flex justify-center gap-0.5 list-none m-0 p-0">
            {navLinks.map((link) => {
                const active = isActive(link.href);
                return (
                    <li>
                        <a
                            href={link.href}
                            class:list={[
                                'relative block px-4 py-2.5 font-mono text-xs uppercase tracking-mono transition-colors',
                                active ? 'text-ink pl-[22px]' : 'text-ink-3 hover:text-ink'
                            ]}
                        >
                            {active && (
                                <span aria-hidden="true" class="absolute left-1 top-2.5 text-ink text-[11px]">→</span>
                            )}
                            {link.text}
                        </a>
                    </li>
                );
            })}
        </ul>

        <div class="flex items-center justify-end min-w-[44px]">
            <button
                type="button"
                class="menu-toggle md:hidden flex flex-col gap-1 bg-transparent border-0 p-2 cursor-pointer"
                aria-label="Open menu"
                aria-expanded="false"
                aria-controls="mobile-menu"
            >
                <span class="block w-[22px] h-px bg-ink transition-all"></span>
                <span class="block w-[22px] h-px bg-ink transition-all"></span>
                <span class="block w-[22px] h-px bg-ink transition-all"></span>
            </button>
        </div>
    </div>

    <ul
        id="mobile-menu"
        class="mobile-menu list-none m-0 p-0 hidden flex-col border-t border-hair md:hidden"
        aria-hidden="true"
    >
        {navLinks.map((link) => {
            const active = isActive(link.href);
            return (
                <li>
                    <a
                        href={link.href}
                        class:list={[
                            'block px-5 py-3.5 font-mono text-[13px] tracking-mono uppercase border-b border-white/5',
                            active ? 'text-ink' : 'text-ink-2 hover:text-ink'
                        ]}
                    >
                        {link.text}
                    </a>
                </li>
            );
        })}
    </ul>
</header>

<style>
    .menu-toggle.is-open span:nth-child(1) { transform: translateY(5px) rotate(45deg); }
    .menu-toggle.is-open span:nth-child(2) { opacity: 0; }
    .menu-toggle.is-open span:nth-child(3) { transform: translateY(-5px) rotate(-45deg); }
    .mobile-menu.is-open { display: flex; }
</style>

<script>
    function wireMenu() {
        const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement | null;
        const menu = document.getElementById('mobile-menu');
        if (!toggle || !menu) return;
        toggle.addEventListener('click', () => {
            const isOpen = toggle.classList.toggle('is-open');
            menu.classList.toggle('is-open', isOpen);
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            toggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
            menu.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
        });
    }
    wireMenu();
    document.addEventListener('astro:after-swap', wireMenu);
</script>
